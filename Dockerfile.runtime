# Dockerfile.runtime
# This Dockerfile creates a minimal runtime container for executing samples.
# Base image: Python 3.12 slim for lightweight Python environment
FROM python:3.12-slim

# Install iptables to allow network blocking within the container
RUN apt-get update && apt-get install -y iptables && rm -rf /var/lib/apt/lists/*

# Set working directory inside the container
WORKDIR /sandbox

# Default command to start Python REPL (can be overridden when executing samples)
CMD ["python3"]
